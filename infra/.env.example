# infra/.env.example — checklist of the Supabase self-host vars you MUST change
# Copy Supabase's own .env (cp .env.example .env in ~/rerevi) and set these.
# Never commit the real .env. These are the security-critical ones.

############ Secrets — generate unique strong values ############
POSTGRES_PASSWORD=        # openssl rand -hex 32
JWT_SECRET=               # 40+ char random; signs tokens
ANON_KEY=                 # derive from JWT_SECRET (Supabase docs / generator)
SERVICE_ROLE_KEY=         # derive from JWT_SECRET — SERVER-SIDE ONLY, never ship to client
DASHBOARD_USERNAME=       # Studio login
DASHBOARD_PASSWORD=       # Studio login — make it strong

############ Public URLs (via the Cloudflare Tunnel) ############
SITE_URL=https://rerevi.zafirshirazi.com
API_EXTERNAL_URL=https://rerevi.zafirshirazi.com
SUPABASE_PUBLIC_URL=https://rerevi.zafirshirazi.com
ADDITIONAL_REDIRECT_URLS=https://rerevi.zsh.name

############ Auth — NO SMTP (no automated email) ############
# We send no transactional email. Trust = admin approval gate. Google = default.
DISABLE_SIGNUP=false          # allow signups; approval gating enforced in-app/RLS
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true # ON: no verification email needed (no SMTP)
# Google OAuth (needs no SMTP) — set here or in Studio → Auth → Providers:
# GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
# GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
# GOTRUE_EXTERNAL_GOOGLE_SECRET=
# Leave all SMTP_* vars blank/unset — email flows (magic link, reset) are disabled.
# Password resets are admin-assisted in the dashboard; users can also use Google.

############ App (added in the build phase) ############
# PUBLIC_SUPABASE_URL=https://rerevi.zafirshirazi.com
# PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>
# CONTACT_EMAIL lives in the DB site_config (editable in admin), not here.
