# REREVI web app — environment template. Copy to `.env` and fill in.
# The anon key is public-safe (RLS protects data). The service role key is NOT —
# it is server-only and must never be exposed to the browser.

PUBLIC_SUPABASE_URL=https://rerevi.zafirshirazi.com
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (admin actions, bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL (used for invite share links, redirects).
PUBLIC_SITE_URL=https://rerevi.zafirshirazi.com
