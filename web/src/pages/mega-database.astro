---
import Base from '@/layouts/Base.astro';
import ComingSoon from '@/components/ComingSoon.astro';
---
<Base title="MEGA RE DATABASE">
  <ComingSoon
    title="MEGA RE DATABASE"
    blurb="Every RE file worth having, gathered in one place — notes, past resources, knowledge organisers and more, as a big downloadable bundle."
