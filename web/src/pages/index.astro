---
import Base from '@/layouts/Base.astro';
import Countdown from '@/components/Countdown.astro';
import { createServerClient } from '@/lib/supabase';

const supabase = createServerClient(Astro.cookies, Astro.request.headers);
const { data: config } = await supabase
  .from('site_config')
  .select('exam_date, brand_name')
  .single();

const examDate = config?.exam_date ?? '2027-06-01';

const tools = [
  { href: '/generator', icon: '📝', title: 'Paper & Question Generator', body: 'Build exam-shaped papers or drill specific topics — with mark schemes and AI marking.' },
  { href: '/question-lookup', icon: '🔎', title: 'Question Lookup', body: 'Jump straight to any question by its QID and reveal its mark scheme.' },
  { href: '/ai-marking', icon: '🤖', title: 'AI Marking', body: 'Copy a ready-made prompt into any AI to get an approximate Eduqas-style mark.' },
  { href: '/how-to-revise', icon: '🧭', title: 'How to Revise', body: 'A practical guide to using REREVI to actually move your grade.' },
  { href: '/topic-summaries', icon: '📚', title: 'Topic Summaries', body: 'Concise per-topic notes for the whole spec.', soon: true },
  { href: '/mega-database', icon: '🗄️', title: 'MEGA RE DATABASE', body: 'Every RE file in one place — a big downloadable bundle.', soon: true },
];
---
<Base>
  <section class="hero">
    <div class="hero-text">
      <span class="pill">Eduqas Route A · Christianity & Islam</span>
      <h1 class="hero-title">Revise GCSE RS, properly.</h1>
      <p class="lede muted">
        REREVI turns the Eduqas spec into practice papers, mark schemes and instant
        AI feedback — so you spend less time organising and more time answering.
      </p>
      <div class="hero-actions">
        <a href="/generator" class="btn btn-primary">Generate a paper →</a>
        <a href="/how-to-revise" class="btn">How to revise</a>
      </div>
    </div>
    <Countdown examDate={examDate} />
  </section>

  <section class="tools">
    {tools.map((t) => (
      <a href={t.href} class="tool card">
        <div class="tool-icon" aria-hidden="true">{t.icon}</div>
        <div>
          <h3 class="tool-title">
            {t.title}
            {t.soon && <span class="pill pill-muted">soon</span>}
          </h3>
          <p class="muted">{t.body}</p>
        </div>
      </a>
    ))}
  </section>

  <section class="card guide-teaser">
    <div>
      <h2>New here? Start with the 3-step loop.</h2>
      <p class="muted">
        <strong>1.</strong> Generate a paper for a topic you've covered. ·
        <strong>2.</strong> Answer it under timed conditions. ·
        <strong>3.</strong> Mark it with AI or the mark scheme, then save the score
        and watch the trend.
      </p>
    </div>
    <a href="/how-to-revise" class="btn btn-primary">Read the guide</a>
  </section>
</Base>

<style>
  .hero { display: grid; grid-template-columns: 1.4fr 1fr; gap: 2rem; align-items: center; margin-bottom: 2.5rem; }
  .hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); margin: 0.6rem 0; }
  .lede { font-size: 1.1rem; max-width: 46ch; }
  .hero-actions { display: flex; gap: 0.6rem; margin-top: 1.2rem; flex-wrap: wrap; }
  .tools { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .tool { display: flex; gap: 0.9rem; align-items: start; color: inherit; transition: transform 0.1s, border-color 0.15s; }
  .tool:hover { text-decoration: none; transform: translateY(-2px); border-color: var(--accent); }
  .tool-icon { font-size: 1.6rem; }
  .tool-title { margin: 0 0 0.3rem; font-size: 1.05rem; display: flex; gap: 0.5rem; align-items: center; }
  .guide-teaser { display: flex; gap: 1.5rem; align-items: center; justify-content: space-between; flex-wrap: wrap; }
  @media (max-width: 820px) { .hero { grid-template-columns: 1fr; } }
</style>
