---
import { NAV } from '@/lib/nav';
import ThemeControls from './ThemeControls.astro';

const path = Astro.url.pathname;
const { user, profile, isAdmin } = Astro.locals;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---
<header class="topbar no-print">
  <div class="container topbar-inner">
    <a href="/" class="brand display" aria-label="REREVI home">REREVI</a>

    <button id="nav-toggle" class="btn btn-sm nav-burger" aria-label="Menu" aria-expanded="false">☰</button>

    <nav id="nav-links" class="nav-links">
      {NAV.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: !item.external && isActive(item.href) }]}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener' : undefined}
        >
          {item.label}
          {item.comingSoon && <span class="pill pill-muted soon">soon</span>}
        </a>
      ))}
    </nav>

    <div class="nav-right">
      <button id="invite-btn" class="btn btn-sm" type="button" title="Share REREVI">↗ Invite</button>
      <ThemeControls />
      {user ? (
        <a href="/account" class:list={['btn', 'btn-sm', { 'btn-primary': isActive('/account') }]}>
          {profile?.display_name || 'Account'}
        </a>
      ) : (
        <a href="/sign-in" class="btn btn-sm btn-primary">Sign in</a>
      )}
      {isAdmin && <a href="/admin" class="btn btn-sm" title="Admin dashboard">⚙ Admin</a>}
    </div>
  </div>
</header>

<style>
  .topbar {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: saturate(1.2) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .topbar-inner { display: flex; align-items: center; gap: 1rem; min-height: 60px; flex-wrap: wrap; }
  .brand { font-size: 1.5rem; color: var(--accent-strong); letter-spacing: 0.04em; }
  .brand:hover { text-decoration: none; }
  .nav-links { display: flex; align-items: center; gap: 0.25rem; flex: 1; flex-wrap: wrap; }
  .nav-link {
    color: var(--text); font-size: 0.9rem; padding: 0.4rem 0.6rem; border-radius: 8px;
    display: inline-flex; align-items: center; gap: 0.35rem;
  }
  .nav-link:hover { background: var(--surface-2); text-decoration: none; }
  .nav-link.active { color: var(--accent-strong); background: var(--accent-soft); }
  .soon { font-size: 0.6rem; padding: 0.1rem 0.4rem; }
  .nav-right { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .nav-burger { display: none; }

  @media (max-width: 900px) {
    .nav-burger { display: inline-flex; margin-left: auto; }
    .nav-links {
      flex-basis: 100%; flex-direction: column; align-items: stretch;
      display: none; padding-bottom: 0.5rem;
    }
    .nav-links.open { display: flex; }
    .nav-right { flex-basis: 100%; }
  }
</style>

<script is:inline>
  (function () {
    var t = document.getElementById('nav-toggle');
    var links = document.getElementById('nav-links');
    if (t && links) t.addEventListener('click', function () {
      var open = links.classList.toggle('open');
      t.setAttribute('aria-expanded', String(open));
    });
    var inv = document.getElementById('invite-btn');
    if (inv) inv.addEventListener('click', async function () {
      var url = window.location.origin;
      var data = { title: 'REREVI — GCSE RS revision', text: 'Revise GCSE Eduqas RS with REREVI:', url: url };
      try {
        if (navigator.share) { await navigator.share(data); return; }
        await navigator.clipboard.writeText(url);
        inv.textContent = '✓ Link copied';
        setTimeout(function () { inv.textContent = '↗ Invite'; }, 1800);
      } catch (e) {}
    });
  })();
</script>
